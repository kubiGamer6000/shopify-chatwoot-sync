SHOPIFY_STORE_DOMAIN=yourstore.myshopify.com
SHOPIFY_CLIENT_ID=your_client_id_from_dev_dashboard
SHOPIFY_CLIENT_SECRET=shpss_your_client_secret
CHATWOOT_BASE_URL=https://app.chatwoot.com
CHATWOOT_API_TOKEN=your_chatwoot_api_access_token
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_INBOX_ID=1
SYNC_API_KEY=generate_a_random_secret_here
SYNC_INTERVAL_HOURS=6
PORT=8080

# AI Pipeline
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key
CLAUDE_MODEL=claude-sonnet-4-6-20260320
SEVENTEENTRACK_API_KEY=your_17track_api_key
CHATWOOT_WEBHOOK_SECRET=optional_secret_for_webhook_url

# AI Mode: shadow (private notes only), live (full agent bot), off (disabled)
AI_MODE=shadow

# Optional: Agent Bot token (messages show as "Bot" in Chatwoot UI)
CHATWOOT_BOT_TOKEN=

# Optional: Override AI prompt files via env (leave unset to use src/config/prompts/*.txt)
# CLASSIFIER_PROMPT=
# RESPONDER_PROMPT=
# HANDOFF_DRAFT_PROMPT=
